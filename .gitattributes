# MoonBit source files
*.mbt linguist-language=MoonBit
moon.mod linguist-language=MoonBit
moon.pkg linguist-language=MoonBit

# Shadcn auto-generated UI (6000+ lines — not our code)
web/src/components/ui/** linguist-generated=true

# Next.js generated boilerplate
web/next-env.d.ts linguist-generated=true
web/components.json linguist-generated=true

# Build/config files (not source code)
web/scripts/** linguist-documentation
web/postcss.config.mjs linguist-documentation
web/eslint.config.mjs linguist-documentation
web/.babelrc linguist-documentation
web/.coze linguist-documentation
web/.npmrc linguist-documentation
web/AGENTS.md linguist-documentation
web/DESIGN.md linguist-documentation
